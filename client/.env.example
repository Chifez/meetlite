# ===========================================
# MeetLite Frontend Environment Variables
# ===========================================
# Copy this file to .env and update the values

# API Gateway URL - single entry point for all API calls
# Development: http://localhost:3000
# Production: https://your-api-gateway-domain.com
VITE_API_GATEWAY_URL=http://localhost:3000

# Base URL for the frontend application
# Development: http://localhost:5174
# Production: https://your-frontend-domain.com
VITE_BASE_URL=http://localhost:5174

# Signaling server URL (for WebRTC)
# Development: http://localhost:5002
# Production: https://your-signaling-server.com
VITE_SIGNALING_SERVER_URL=http://localhost:5002

# ===========================================
# OAuth Configuration
# ===========================================

# Google OAuth Client ID (from Google Cloud Console)
# Get this from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Microsoft OAuth Client ID (optional)
# Get this from: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
VITE_MICROSOFT_CLIENT_ID=your_microsoft_client_id_here

# ===========================================
# Push Notifications (VAPID)
# ===========================================

# VAPID Public Key for push notifications
# Generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# ===========================================
# Development vs Production
# ===========================================

# For development, use:
# VITE_API_GATEWAY_URL=http://localhost:3000
# VITE_BASE_URL=http://localhost:5174

# For production, use:
# VITE_API_GATEWAY_URL=https://your-api-gateway.onrender.com
# VITE_BASE_URL=https://your-app.netlify.app
