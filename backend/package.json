{
  "name": "meetlite-backend",
  "version": "1.0.0",
  "description": "Backend services for MeetLite video meeting application",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces",
    "dev:auth": "npm run dev --workspace=@minimeet/auth-service",
    "dev:room": "npm run dev --workspace=@minimeet/room-service",
    "dev:mediasoup": "npm run dev --workspace=@minimeet/mediasoup-service",
    "dev:gateway": "npm run dev --workspace=@minimeet/api-gateway",
    "dev:all": "concurrently \"npm run dev:gateway\" \"npm run dev:auth\" \"npm run dev:room\" \"npm run dev:mediasoup\"",
    "install:all": "npm install",
    "build:all": "npm run build --workspaces",
    "test:all": "npm run test --workspaces",
    "start": "npm run start --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}