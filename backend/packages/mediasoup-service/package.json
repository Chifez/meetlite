{
  "name": "@minimeet/mediasoup-service",
  "version": "1.0.0",
  "description": "MediaSoup media server for WebRTC video conferencing",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src -e ts --exec \"tsc && node dist/index.js\"",
    "dev:no-watch": "tsc && node dist/index.js",
    "start": "node dist/index.js",
    "build": "tsc"
  },
  "dependencies": {
    "@minimeet/shared": "*",
    "@tldraw/sync-core": "^3.15.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "lib0": "^0.2.97",
    "mediasoup": "^3.12.0",
    "mediasoup-client": "^3.7.7",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "socket.io": "^4.7.5",
    "winston": "^3.11.0",
    "ws": "^8.16.0",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.18"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.0",
    "@types/ws": "^8.18.1",
    "nodemon": "^3.1.10",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mediasoup",
    "webrtc",
    "video",
    "conferencing",
    "microservice"
  ]
}
