# MediaSoup Service Configuration
PORT=3003
NODE_ENV=development

# Client Configuration
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# MediaSoup Configuration
ANNOUNCED_IP=
RTC_MIN_PORT=10000
RTC_MAX_PORT=10100

# TURN Servers (JSON array format)
TURN_SERVERS=[]

# Logging
LOG_LEVEL=info

# Authentication
JWT_SECRET=your_jwt_secret_key_here

# Room Service Integration
ROOM_SERVICE_URL=http://localhost:5001

# MediaSoup Worker Configuration
WORKER_LOG_LEVEL=debug
WORKER_LOG_TAGS=info,ice,dtls,rtp,srtp,rtcp,rtx,bwe,score,simulcast,svc
