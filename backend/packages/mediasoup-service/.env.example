# ===========================================
# MeetLite MediaSoup Service Environment Variables
# ===========================================
# Copy this file to .env and update the values

# ===========================================
# Server Configuration
# ===========================================

# Port for the MediaSoup service
# Development: 3003
# Production: Use your hosting provider's port
PORT=3003

# Node environment
NODE_ENV=development

# ===========================================
# Frontend Configuration
# ===========================================

# Frontend URL
# Development: http://localhost:5174
# Production: https://your-frontend-domain.com
CLIENT_URL=http://localhost:5174
CORS_ORIGIN=http://localhost:5174

# ===========================================
# API Gateway Configuration
# ===========================================

# API Gateway URL (for internal communication)
# Development: http://localhost:3000
# Production: https://your-api-gateway-domain.com
API_GATEWAY_URL=http://localhost:3000

# ===========================================
# Authentication & Security
# ===========================================

# JWT Secret Key (must match auth-service)
JWT_SECRET=your_super_secret_jwt_key_here

# ===========================================
# MediaSoup Configuration
# ===========================================

# MediaSoup announced IP (for WebRTC)
# Development: Leave empty for localhost
# Production: Your server's public IP address
ANNOUNCED_IP=

# TURN servers (for NAT traversal)
# Development: Leave empty
# Production: Add your TURN server URLs
TURN_SERVERS=[]

# RTC port range (for WebRTC media)
RTC_MIN_PORT=10000
RTC_MAX_PORT=10100

# ===========================================
# Logging Configuration
# ===========================================

# Log level (debug, info, warn, error)
LOG_LEVEL=debug

# MediaSoup worker log level
WORKER_LOG_LEVEL=debug

# MediaSoup worker log tags
WORKER_LOG_TAGS=info,ice,dtls,rtp,srtp,rtcp,rtx,bwe,score,simulcast,svc

# ===========================================
# Database Configuration
# ===========================================

# Redis Configuration (for session storage)
REDIS_URL=redis://localhost:6379

# ===========================================
# File Upload Configuration
# ===========================================

# Directory for file uploads
UPLOAD_DIR=uploads

# ===========================================
# Service URLs (Internal Communication)
# ===========================================

# Room Service URL (for collaboration features)
# Development: http://localhost:5001
# Production: https://your-room-service.onrender.com
ROOM_SERVICE_URL=http://localhost:5001

# ===========================================
# Development vs Production Examples
# ===========================================

# Development Configuration:
# PORT=3003
# NODE_ENV=development
# CLIENT_URL=http://localhost:5174
# API_GATEWAY_URL=http://localhost:3000
# ANNOUNCED_IP=
# RTC_MIN_PORT=10000
# RTC_MAX_PORT=10100

# Production Configuration:
# PORT=3000
# NODE_ENV=production
# CLIENT_URL=https://your-app.netlify.app
# API_GATEWAY_URL=https://your-api-gateway.onrender.com
# ANNOUNCED_IP=your_server_public_ip
# RTC_MIN_PORT=10000
# RTC_MAX_PORT=20000
# TURN_SERVERS=["turn:your-turn-server.com:3478"]
# LOG_LEVEL=info
# WORKER_LOG_LEVEL=warn

# ===========================================
# Important Notes for Production
# ===========================================

# 1. Set ANNOUNCED_IP to your server's public IP
# 2. Configure TURN servers for NAT traversal
# 3. Open UDP ports RTC_MIN_PORT to RTC_MAX_PORT
# 4. Use a production Redis instance
# 5. Set appropriate log levels (info/warn instead of debug)
# 6. Configure proper file upload limits and storage