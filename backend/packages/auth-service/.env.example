# ===========================================
# MeetLite Backend Environment Variables
# ===========================================
# Copy this file to .env and update the values

# ===========================================
# Server Configuration
# ===========================================

# Port for the auth service
# Development: 5000
# Production: Use your hosting provider's port (usually 3000 or 5000)
PORT=5000

# Node environment
NODE_ENV=development

# ===========================================
# Database Configuration
# ===========================================

# MongoDB Connection String
# Development: mongodb://localhost:27017/meetlite_auth
# Production: mongodb+srv://username:password@cluster.mongodb.net/meetlite_auth
MONGODB_URI=mongodb://localhost:27017/meetlite_auth

# PostgreSQL Connection String (Prisma)
# Development: postgresql://postgres:postgres@localhost:5432/meetlite?schema=public
# Production: postgresql://username:password@hostname:5432/dbname?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meetlite?schema=public

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# Authentication & Security
# ===========================================

# JWT Secret Key (generate a strong random string)
# Use: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Session Configuration
SESSION_SECRET=your_session_secret_here
SESSION_NAME=meetlite_session
SESSION_MAX_AGE=86400000

# ===========================================
# CORS Configuration
# ===========================================

# Frontend URL (where your React app is hosted)
# Development: http://localhost:5174
# Production: https://your-frontend-domain.com
CORS_ORIGIN=http://localhost:5174
CLIENT_URL=http://localhost:5174
FRONTEND_URL=http://localhost:5174

# ===========================================
# OAuth Configuration
# ===========================================

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Google OAuth Redirect URI
# Development: http://localhost:3000/api/auth/google/callback
# Production: https://your-api-gateway-domain.com/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Microsoft OAuth (optional)
# MICROSOFT_CLIENT_ID=your_microsoft_client_id_here
# MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret_here
# MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/microsoft/callback

# ===========================================
# Email Configuration (SMTP)
# ===========================================

# SMTP Server Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=hello@meetlite.app
SMTP_FROM_NAME=MeetLite
SMTP_SECURE=false

# Alternative SMTP providers:
# For SendGrid: smtp.sendgrid.net
# For Mailgun: smtp.mailgun.org
# For AWS SES: email-smtp.us-east-1.amazonaws.com

# ===========================================
# Payment Processing (Stripe)
# ===========================================

# Stripe API Keys (get from Stripe Dashboard)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (create products in Stripe Dashboard)
STRIPE_PRO_MONTHLY_PRICE_ID=price_your_pro_monthly_id
STRIPE_PRO_YEARLY_PRICE_ID=price_your_pro_yearly_id
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_your_enterprise_monthly_id
STRIPE_ENTERPRISE_YEARLY_PRICE_ID=price_your_enterprise_yearly_id

# ===========================================
# Push Notifications (VAPID)
# ===========================================

# VAPID Keys for push notifications
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:your_email@example.com

# ===========================================
# File Storage & Media
# ===========================================

# Logo URL (for email templates)
LOGO_URL=https://your-cdn-domain.com/logo.png

# ===========================================
# Development vs Production Examples
# ===========================================

# Development Configuration:
# PORT=5000
# NODE_ENV=development
# MONGODB_URI=mongodb://localhost:27017/meetlite_auth
# CORS_ORIGIN=http://localhost:5174
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Production Configuration:
# PORT=3000
# NODE_ENV=production
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/meetlite_auth
# CORS_ORIGIN=https://your-app.netlify.app
# GOOGLE_REDIRECT_URI=https://your-api-gateway.onrender.com/api/auth/google/callback
# JWT_SECRET=your_production_jwt_secret_here
# SESSION_SECRET=your_production_session_secret_here
