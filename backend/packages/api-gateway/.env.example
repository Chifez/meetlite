# ===========================================
# MeetLite API Gateway Environment Variables
# ===========================================
# Copy this file to .env and update the values

# ===========================================
# Server Configuration
# ===========================================

# Port for the API Gateway
# Development: 3000
# Production: Use your hosting provider's port
PORT=3000

# Node environment
NODE_ENV=development

# ===========================================
# Frontend Configuration
# ===========================================

# Frontend URL (where your React app is hosted)
# Development: http://localhost:5174
# Production: https://your-frontend-domain.com
FRONTEND_URL=http://localhost:5174

# ===========================================
# Service URLs (Internal Communication)
# ===========================================

# Auth Service URL
# Development: http://localhost:5000
# Production: https://your-auth-service.onrender.com
AUTH_SERVICE_URL=http://localhost:5000

# Room Service URL
# Development: http://localhost:5001
# Production: https://your-room-service.onrender.com
ROOM_SERVICE_URL=http://localhost:5001

# MediaSoup Service URL
# Development: http://localhost:3003
# Production: https://your-mediasoup-service.onrender.com
MEDIASOUP_SERVICE_URL=http://localhost:3003

# ===========================================
# CORS Configuration
# ===========================================

# Allowed origins for CORS
# Development: Include all your dev ports
# Production: Only your production domains
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost:4173,http://localhost:4174

# ===========================================
# Development vs Production Examples
# ===========================================

# Development Configuration:
# PORT=3000
# NODE_ENV=development
# FRONTEND_URL=http://localhost:5174
# AUTH_SERVICE_URL=http://localhost:5000
# ROOM_SERVICE_URL=http://localhost:5001
# MEDIASOUP_SERVICE_URL=http://localhost:3003

# Production Configuration:
# PORT=3000
# NODE_ENV=production
# FRONTEND_URL=https://your-app.netlify.app
# AUTH_SERVICE_URL=https://meetlite-auth-service.onrender.com
# ROOM_SERVICE_URL=https://meetlite-room-service.onrender.com
# MEDIASOUP_SERVICE_URL=https://meetlite-mediasoup-service.onrender.com
# CORS_ORIGINS=https://your-app.netlify.app
