# ===========================================
# MeetLite Room Service Environment Variables
# ===========================================
# Copy this file to .env and update the values

# ===========================================
# Server Configuration
# ===========================================

# Port for the room service
# Development: 5001
# Production: Use your hosting provider's port
PORT=5001

# Node environment
NODE_ENV=development

# ===========================================
# Database Configuration
# ===========================================

# MongoDB Connection String
# Development: mongodb://localhost:27017/meetlite_rooms
# Production: mongodb+srv://username:password@cluster.mongodb.net/meetlite_rooms
MONGODB_URI=mongodb://localhost:27017/meetlite_rooms

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

# ===========================================
# Authentication & Security
# ===========================================

# JWT Secret Key (must match auth-service)
JWT_SECRET=your_super_secret_jwt_key_here

# Session Configuration
SESSION_SECRET=your_session_secret_here
SESSION_NAME=meetlite_session
SESSION_MAX_AGE=86400000

# ===========================================
# CORS Configuration
# ===========================================

# Frontend URL
# Development: http://localhost:5174
# Production: https://your-frontend-domain.com
CORS_ORIGIN=http://localhost:5174
CLIENT_URL=http://localhost:5174

# ===========================================
# Email Configuration (SMTP)
# ===========================================

# SMTP Server Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=noreply@meetlite.app
SMTP_FROM_NAME=MeetLite
SMTP_SECURE=false

# ===========================================
# AI Service Configuration
# ===========================================

# OpenAI API Key (for AI features)
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# OpenRouter API Key (alternative AI provider)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here

# Google Cloud Speech-to-Text
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/google-credentials.json

# ===========================================
# Calendar Integration
# ===========================================

# Google Calendar OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5001/api/calendar/google/callback

# Microsoft Calendar OAuth (optional)
# MICROSOFT_CLIENT_ID=your_microsoft_client_id_here
# MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret_here
# MICROSOFT_REDIRECT_URI=http://localhost:5001/api/calendar/microsoft/callback

# ===========================================
# File Storage Configuration
# ===========================================

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Cloudflare R2 Configuration (for recordings)
CLOUDFLARE_R2_ACCOUNT_ID=your_r2_account_id
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=meetlite-recordings
CLOUDFLARE_R2_PUBLIC_ACCESS=false
CLOUDFLARE_R2_SIGNED_URL_EXPIRY=3600
CLOUDFLARE_R2_ENDPOINTS=https://your_account_id.r2.cloudflarestorage.com

# Logo URL (for email templates)
LOGO_URL=https://your-cdn-domain.com/logo.png

# ===========================================
# Development vs Production Examples
# ===========================================

# Development Configuration:
# PORT=5001
# NODE_ENV=development
# MONGODB_URI=mongodb://localhost:27017/meetlite_rooms
# CORS_ORIGIN=http://localhost:5174
# GOOGLE_REDIRECT_URI=http://localhost:5001/api/calendar/google/callback

# Production Configuration:
# PORT=3000
# NODE_ENV=production
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/meetlite_rooms
# CORS_ORIGIN=https://your-app.netlify.app
# GOOGLE_REDIRECT_URI=https://your-room-service.onrender.com/api/calendar/google/callback