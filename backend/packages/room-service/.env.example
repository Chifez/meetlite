# Cloudflare R2 Configuration
# ===========================
# 
# To use Cloudflare R2 for storing recordings and files, you need to:
# 
# 1. Create a Cloudflare R2 bucket:
#    - Log into Cloudflare Dashboard
#    - Go to R2 Object Storage
#    - Create a new bucket (e.g., "minimeet-recordings")
# 
# 2. Generate API credentials:
#    - Go to R2 > Manage R2 API Tokens
#    - Click "Create API Token"
#    - Name: "MiniMeet Recordings Access"
#    - Permissions: "Admin Read & Write"
#    - Scope: "All buckets" or specific bucket
#    - Expiration: Set as needed (or "Never")
# 
# 3. Get your Account ID:
#    - Found in the right sidebar of your Cloudflare dashboard
#    - Or in R2 > Settings > Account ID
# 
# 4. Add these variables to your .env file:

# Cloudflare R2 Account ID (found in dashboard sidebar)
CLOUDFLARE_R2_ACCOUNT_ID=your_account_id_here

# R2 API Token Access Key ID
CLOUDFLARE_R2_ACCESS_KEY_ID=your_access_key_id_here

# R2 API Token Secret Access Key  
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_secret_access_key_here

# R2 Bucket Name (the bucket you created)
CLOUDFLARE_R2_BUCKET_NAME=minimeet-recordings

# Optional: Custom domain for R2 bucket (if you have one)
# CLOUDFLARE_R2_CUSTOM_DOMAIN=recordings.yourdomain.com

# Optional: Enable public access (set to true if bucket is public)
CLOUDFLARE_R2_PUBLIC_ACCESS=false

# Optional: Default expiration for signed URLs (in seconds)
CLOUDFLARE_R2_SIGNED_URL_EXPIRY=3600

# Email Logo URL (Cloudinary URL for email templates only)
# This is the only remaining Cloudinary usage - just the logo URL
LOGO_URL=https://res.cloudinary.com/your-cloud-name/image/upload/v1234567890/logo.png

# ===========================
# Cost Optimization Tips:
# ===========================
# 
# 1. Use lifecycle rules to automatically delete old recordings
# 2. Enable compression for video files
# 3. Use different storage classes for different file types
# 4. Set up Cloudflare Workers for custom processing
# 5. Monitor usage in Cloudflare dashboard
# 
# ===========================
# Security Best Practices:
# ===========================
# 
# 1. Use signed URLs for private content
# 2. Set appropriate CORS policies
# 3. Enable bucket versioning for important files
# 4. Use IAM policies to restrict access
# 5. Monitor access logs
# 
# ===========================
# Email Templates:
# ===========================
# 
# The email templates use LOGO_URL for the brand logo.
# This is the only remaining Cloudinary usage - just the logo URL.
# All other file storage now uses Cloudflare R2.
